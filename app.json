{
  "expo": {
    "name": "مولدي",
    "slug": "mawledy",
    "version": "1.1.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "sdkVersion": "56.0.0",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.essam.mowldey"
    },
    "android": {
      "package": "com.essam.mowldey",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-camera",
        {
          "cameraPermission": "السماح بالوصول للكاميرا لمسح الباركود"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "السماح بالوصول للصور لاختيار باركود"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d5d85716-a626-4455-ad42-8a6394888511"
      }
    }
  }
}
